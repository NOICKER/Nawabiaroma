PORT=4000
NODE_ENV=development
DATABASE_MODE=LOCAL_DEV
# Use DATABASE_URL as the active connection string for the current environment.
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# LOCAL_DEV prefers the Supabase pooler URL. PRODUCTION prefers the direct URL.
DATABASE_URL_POOLER=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL_DIRECT=postgresql://postgres:<url-encoded-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
CORS_ORIGIN=http://localhost:5173
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=razorpay_secret_placeholder
RAZORPAY_WEBHOOK_SECRET=razorpay_webhook_secret_placeholder
JWT_SECRET=replace-with-long-secret
JWT_ISSUER=nawabi-aroma
JWT_AUDIENCE=nawabi-admin
RESEND_API_KEY=re_placeholder
ORDER_EMAIL_FROM=Nawabi <orders@example.com>
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=aws_access_key_id_placeholder
AWS_SECRET_ACCESS_KEY=aws_secret_access_key_placeholder
S3_BUCKET_NAME=s3_bucket_name_placeholder
S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_UPLOAD_PREFIX=products

# Rate Limiting
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100
CHECKOUT_RATE_LIMIT_WINDOW_MS=60000
CHECKOUT_RATE_LIMIT_MAX=10
ADMIN_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=30
